# Copy this file to ".env" and fill in the two values from your Supabase project.
# Supabase Dashboard -> Project Settings -> API
#
# IMPORTANT: only the public "anon" key goes here. NEVER put the service_role key
# in this file or anywhere in the frontend. Row Level Security protects the data.

# Project URL, e.g. https://abcdefghijklmnop.supabase.co
VITE_SUPABASE_URL=

# The "anon public" API key (safe to ship in a static site).
VITE_SUPABASE_ANON_KEY=
